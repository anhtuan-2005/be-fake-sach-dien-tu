{
  "name": "backend",
  "version": "1.0.0",
  "description": "Dự án Fake Sách Điện Tử - Tuấn Anh",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
